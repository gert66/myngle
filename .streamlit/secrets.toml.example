# Streamlit secrets template — copy to `.streamlit/secrets.toml` and fill in real values.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# The real `.streamlit/secrets.toml` is gitignored and must NEVER be committed.
# These keys are read by the Streamlit app via `st.secrets` (see enrich_clients_claude.py).
# For the CLI / debug-trace / API-server paths, the same names are read from
# environment variables instead (os.environ).

# --- Required for Lead Prioritizer v2 live validation ---
SERPER_API_KEY = "your-serper-api-key-here"       # Step 2 Google search (Serper)
ANTHROPIC_API_KEY = "your-anthropic-api-key-here" # Claude Step 1 + Step 2 signal extraction

# --- Optional ---
# LUSHA_API_KEY = "your-lusha-api-key-here"        # Optional enrichment provider
# SHOW_ADVANCED_SETTINGS = false

# --- GCS access for hosted Streamlit apps (rescore / caller reallocation) ---
# Only needed where the gcloud/gsutil CLI is NOT installed (e.g. Streamlit
# Community Cloud) — locally the CLI is preferred and this can stay unset.
# Paste the fields of a service-account key JSON (IAM > Service Accounts >
# Keys > Add key). The account needs Storage Object Admin on the bucket
# (or Storage Object Viewer for read-only use). Read by gcs_python_backend.py.
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "streamlit-apps@your-project-id.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/streamlit-apps%40your-project-id.iam.gserviceaccount.com"
# universe_domain = "googleapis.com"
